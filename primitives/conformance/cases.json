{
  "_doc": "Language-neutral conformance cases for the provenance law and checker. JS and Python runners load this file and must produce identical results. Keys are camelCase (the canonical envelope shape); the Python runner translates to snake_case. This file — not prose — is the parity contract.",
  "version": 1,
  "combine": [
    {
      "name": "real + mock — taint, weakest confidence, weakest source, numeric floor",
      "inputs": [
        { "source": "real", "confidence": "high", "confidenceScore": 0.9, "derivedFromMock": false, "lineage": [] },
        { "source": "mock", "confidence": "low", "confidenceScore": 0.2, "derivedFromMock": true, "lineage": [] }
      ],
      "expect": { "derivedFromMock": true, "confidence": "low", "source": "derived", "weakestSource": "mock", "confidenceScore": 0.2 }
    },
    {
      "name": "real + semiReal — stays clean, medium confidence, weakest source semiReal",
      "inputs": [
        { "source": "real", "confidence": "high", "confidenceScore": 0.9, "derivedFromMock": false, "lineage": [] },
        { "source": "semiReal", "confidence": "medium", "confidenceScore": 0.6, "derivedFromMock": false, "lineage": [] }
      ],
      "expect": { "derivedFromMock": false, "confidence": "medium", "source": "derived", "weakestSource": "semiReal", "confidenceScore": 0.6 }
    },
    {
      "name": "partial numeric coverage — score omitted because one input lacks it",
      "inputs": [
        { "source": "real", "confidence": "high", "confidenceScore": 0.9, "derivedFromMock": false, "lineage": [] },
        { "source": "real", "confidence": "high", "derivedFromMock": false, "lineage": [] }
      ],
      "expect": { "derivedFromMock": false, "confidence": "high", "weakestSource": "real" },
      "absent": ["confidenceScore"]
    },
    {
      "name": "three inputs — taint ORs across all",
      "inputs": [
        { "source": "real", "confidence": "high", "derivedFromMock": false, "lineage": [] },
        { "source": "real", "confidence": "high", "derivedFromMock": false, "lineage": [] },
        { "source": "mock", "confidence": "low", "derivedFromMock": true, "lineage": [] }
      ],
      "expect": { "derivedFromMock": true, "confidence": "low", "weakestSource": "mock" }
    },
    {
      "name": "zero inputs — unavailable (derived-from-nothing), no lineage, no weakest source, no numeric score",
      "inputs": [],
      "expect": { "derivedFromMock": false, "confidence": "none", "source": "unavailable" },
      "absent": ["weakestSource", "confidenceScore"]
    },
    {
      "name": "inferred + fallback — inferred is the weaker source",
      "inputs": [
        { "source": "fallback", "confidence": "low", "derivedFromMock": false, "lineage": [] },
        { "source": "inferred", "confidence": "low", "derivedFromMock": false, "lineage": [] }
      ],
      "expect": { "source": "derived", "confidence": "low", "weakestSource": "inferred", "derivedFromMock": false }
    },
    {
      "name": "content-addressed lineage ids — real + mock, ids are stable sha256 (#52)",
      "inputs": [
        { "source": "real", "confidence": "high", "derivedFromMock": false, "lineage": [] },
        { "source": "mock", "confidence": "low", "derivedFromMock": true, "lineage": [] }
      ],
      "expect": { "source": "derived", "derivedFromMock": true, "weakestSource": "mock" },
      "expectLineageIds": ["sha256:097181b20233", "sha256:16b0cc5a3c46"]
    },
    {
      "name": "content-addressed lineage ids — scored inputs pin the confidenceScore branch of the id hash (#52)",
      "inputs": [
        { "source": "real", "confidence": "high", "confidenceScore": 0.9, "derivedFromMock": false, "lineage": [] },
        { "source": "mock", "confidence": "low", "confidenceScore": 0.2, "derivedFromMock": true, "lineage": [] }
      ],
      "expect": { "source": "derived", "derivedFromMock": true, "weakestSource": "mock", "confidenceScore": 0.2 },
      "expectLineageIds": ["sha256:2bdad8542ba4", "sha256:114b62067db8"]
    },
    {
      "name": "content-addressed lineage ids — sub-1e-4 score exercises the IEEE-754 hex encoding branch (catches JSON.stringify/json.dumps divergence, #52)",
      "inputs": [
        { "source": "real", "confidence": "high", "confidenceScore": 0.9, "derivedFromMock": false, "lineage": [] },
        { "source": "mock", "confidence": "low", "confidenceScore": 0.00001, "derivedFromMock": true, "lineage": [] }
      ],
      "expect": { "source": "derived", "derivedFromMock": true, "weakestSource": "mock", "confidenceScore": 0.00001 },
      "expectLineageIds": ["sha256:2bdad8542ba4", "sha256:4c2bcbf6481c"]
    }
  ],
  "audit": [
    {
      "name": "consistent derived value — no issues",
      "meta": {
        "provenanceVersion": 2,
        "source": "derived", "confidence": "low", "derivedFromMock": true,
        "lineage": [
          { "id": "s1", "of": "input", "source": "real", "confidence": "high", "derivedFromMock": false },
          { "id": "s2", "of": "input", "source": "mock", "confidence": "low", "derivedFromMock": true }
        ]
      },
      "expectContains": []
    },
    {
      "name": "laundering — clean source with taint set",
      "meta": { "source": "real", "confidence": "high", "derivedFromMock": true, "lineage": [] },
      "expectContains": ["laundering"]
    },
    {
      "name": "ordinal over-claiming — confidence above weakest lineage",
      "meta": {
        "source": "derived", "confidence": "high", "derivedFromMock": false,
        "lineage": [ { "id": "s1", "of": "input", "source": "real", "confidence": "low", "derivedFromMock": false } ]
      },
      "expectContains": ["over-claiming: confidence 'high'"]
    },
    {
      "name": "numeric over-claiming — confidenceScore above weakest lineage score",
      "meta": {
        "source": "derived", "confidence": "low", "confidenceScore": 0.9, "derivedFromMock": false,
        "lineage": [ { "id": "s1", "of": "input", "source": "real", "confidence": "low", "confidenceScore": 0.2, "derivedFromMock": false } ]
      },
      "expectContains": ["over-claiming: confidenceScore"]
    },
    {
      "name": "source over-claim — weakestSource cleaner than lineage proves",
      "meta": {
        "source": "derived", "confidence": "low", "derivedFromMock": true, "weakestSource": "real",
        "lineage": [ { "id": "s1", "of": "input", "source": "mock", "confidence": "low", "derivedFromMock": true } ]
      },
      "expectContains": ["source over-claim"]
    },
    {
      "name": "dropped taint — tainted lineage step but derivedFromMock false",
      "meta": {
        "source": "derived", "confidence": "low", "derivedFromMock": false,
        "lineage": [ { "id": "s1", "of": "input", "source": "mock", "confidence": "low", "derivedFromMock": true } ]
      },
      "expectContains": ["taint dropped"]
    },
    {
      "name": "unreproducible — derived source with empty lineage",
      "meta": { "source": "derived", "confidence": "none", "derivedFromMock": false, "lineage": [] },
      "expectContains": ["unreproducible"]
    },
    {
      "name": "zero-input combine output — unavailable with empty lineage audits clean (SPEC §3 ↔ §5)",
      "meta": { "provenanceVersion": 2, "source": "unavailable", "confidence": "none", "derivedFromMock": false, "lineage": [] },
      "expectContains": []
    },
    {
      "name": "null envelope — missing meta",
      "meta": null,
      "expectContains": ["missing meta"]
    },
    {
      "name": "empty envelope — no issues besides the version-legacy advisory (#93: absent version is legacy)",
      "meta": {},
      "expectContains": ["version-legacy:"]
    },
    {
      "name": "non-dict meta (falsy scalar) — missing meta (totality, SPEC §5)",
      "meta": 0,
      "expectContains": ["missing meta"]
    },
    {
      "name": "truthy non-dict meta (string) — missing meta (parity, not an envelope)",
      "meta": "not-an-envelope",
      "expectContains": ["missing meta"]
    },
    {
      "name": "truthy non-dict meta (array) — missing meta (parity)",
      "meta": [1, 2, 3],
      "expectContains": ["missing meta"]
    },
    {
      "name": "version-legacy — envelope without a version is flagged legacy",
      "meta": { "source": "real", "confidence": "high", "derivedFromMock": false, "lineage": [] },
      "expectContains": ["version-legacy:"]
    },
    {
      "name": "version-future — newer version passes with an advisory",
      "meta": { "provenanceVersion": 99, "source": "real", "confidence": "high", "derivedFromMock": false, "lineage": [] },
      "expectContains": ["version-future:"]
    },
    {
      "name": "inferred source is not laundering — no issue on a clean inferred value",
      "meta": { "provenanceVersion": 2, "source": "inferred", "confidence": "low", "derivedFromMock": false, "lineage": [] },
      "expectContains": []
    }
  ],
  "validate": [
    {
      "name": "complete envelope — all four required fields present and well-typed",
      "meta": { "source": "real", "confidence": "high", "derivedFromMock": false, "lineage": [] },
      "expectContains": []
    },
    {
      "name": "complete envelope with optional fields and populated lineage — valid",
      "meta": {
        "source": "derived", "confidence": "low", "derivedFromMock": true,
        "confidenceScore": 0.2, "weakestSource": "mock",
        "lineage": [ { "id": "s1", "of": "input", "source": "mock", "confidence": "low", "derivedFromMock": true } ]
      },
      "expectContains": []
    },
    {
      "name": "empty envelope — all four required fields missing",
      "meta": {},
      "expectContains": [
        "required field: source",
        "required field: confidence",
        "required field: derivedFromMock",
        "required field: lineage"
      ]
    },
    {
      "name": "missing one field — lineage absent",
      "meta": { "source": "real", "confidence": "high", "derivedFromMock": false },
      "expectContains": ["required field: lineage"]
    },
    {
      "name": "wrong type — lineage is not an array",
      "meta": { "source": "real", "confidence": "high", "derivedFromMock": false, "lineage": "nope" },
      "expectContains": ["field 'lineage' must be"]
    },
    {
      "name": "wrong type — derivedFromMock is not a boolean",
      "meta": { "source": "real", "confidence": "high", "derivedFromMock": "false", "lineage": [] },
      "expectContains": ["field 'derivedFromMock' must be"]
    },
    {
      "name": "null envelope — missing meta",
      "meta": null,
      "expectContains": ["missing meta"]
    },
    {
      "name": "non-object envelope — not an envelope at all",
      "meta": "not an envelope",
      "expectContains": ["not an envelope object"]
    }
  ]
}
